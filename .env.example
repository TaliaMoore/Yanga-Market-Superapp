# GEMINI_API_KEY: Required for Gemini AI API calls.
# This is a placeholder key.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY=MY_GEMINI_API_KEY

# Backend server environment configurations
NODE_ENV=development
PORT=3000

# Database credentials (Postgres / MySQL / SQLite, etc.)
# You can define individual parameters:
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=your_secure_password_here
DB_NAME=yanga_market_db

# OR provide a single simple Connection String (highly recommended for mobile use!)
# Example: postgres://username:password@hostname:port/database_name
DATABASE_URL=placeholder_string

